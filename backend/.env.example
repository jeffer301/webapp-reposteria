# ── Base de Datos PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reposteria
DB_USER=postgres
DB_PASSWORD=genera_una_contraseña_segura_aqui

# ── JWT (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_SECRET=genera_un_secret_seguro_aqui

# ── Servidor ──
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# ── SMTP Email (obligatorio en produccion) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contraseña-de-app

# ══════════════════════════════════════════════════
#  PASARELA DE PAGOS
# ══════════════════════════════════════════════════
# Proveedor activo: wompi | stripe | mercadopago
# PAYMENT_PROVIDER=wompi

# ── Wompi ────────────────────────────────────────
# Documentacion: https://docs.wompi.co/
# Sandbox:    https://sandbox.wompi.co/v1
# Produccion: https://production.wompi.co/v1
# WOMPI_API_URL=https://sandbox.wompi.co/v1
# WOMPI_PUBLIC_KEY=pub_test_xxx
# WOMPI_PRIVATE_KEY=prv_test_xxx

# ── Stripe ───────────────────────────────────────
# Requiere: npm install stripe
# Documentacion: https://docs.stripe.com/api
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_CURRENCY=usd

# ── MercadoPago ──────────────────────────────────
# Requiere: npm install mercadopago
# Documentacion: https://www.mercadopago.com.co/developers
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxx
# MERCADOPAGO_CURRENCY=COP
